# =============================================================================
# RPi Dashboard - Configurazione di deploy (TEMPLATE)
# =============================================================================
# Copia questo file e personalizzalo:
#   cp deploy/deploy.env.example deploy/deploy.env
# Il file reale "deploy/deploy.env" e' IGNORATO da git (contiene host/utenti reali).
#
# Usalo con:
#   ./scripts/deploy.sh --mode docker --env-file deploy/deploy.env
#   ./scripts/deploy.sh --mode native --env-file deploy/deploy.env
#
# NOTA SICUREZZA: qui NON vanno password ne' chiavi private. L'autenticazione SSH
# e' solo a chiave. Aggiungi l'host a ~/.ssh/known_hosts prima del primo deploy
# (vedi docs/DEPLOYMENT.md).
# =============================================================================

# --- Destinazione SSH --------------------------------------------------------
# DEPLOY_HOST puo' essere: hostname Tailscale/MagicDNS (consigliato), IP Tailscale
# 100.x, hostname della LAN oppure IP della LAN.
DEPLOY_HOST=rpi-dashboard
DEPLOY_USER=deploy
DEPLOY_PORT=22

# Directory di destinazione sul Raspberry (deve essere assoluta e non "/").
# Per la modalita' native puoi usare anche una directory sotto la home,
# es. /home/<utente>/workspace/dashboard-raspi
DEPLOY_PATH=/home/deploy/workspace/dashboard-raspi

# Modalita' di default (sovrascrivibile con --mode). docker | native
DEPLOY_MODE=native

# --- Porte pubblicate --------------------------------------------------------
# Porta con cui si accede alla dashboard (frontend) e porta del backend/API.
FRONTEND_PORT=8080
BACKEND_PORT=8000

# DEPRECATO: non piu' necessario. Il frontend usa URL relativi e nginx proxy /api
# al backend. Mantenuto solo per compatibilita' con setup esistenti.
# VITE_API_BASE_URL=http://rpi-dashboard:8000

# --- Nginx (solo modalita' native) ------------------------------------------
# Path di destinazione del config nginx sul Raspberry. Se impostato, il deploy
# aggiorna automaticamente il config e ricarica nginx (sudo deve essere abilitato).
# Esempio con sites-available (Raspberry Pi OS / Debian):
#   NGINX_CONF_PATH=/etc/nginx/sites-available/dashboard-raspi
# Esempio con conf.d:
#   NGINX_CONF_PATH=/etc/nginx/conf.d/dashboard-raspi.conf
NGINX_CONF_PATH=

# --- Health check ------------------------------------------------------------
# Endpoint interrogato sul Raspberry dopo il deploy (deve rispondere 200).
HEALTHCHECK_URL=http://localhost:8000/api/health
# Tentativi e attesa (secondi) tra un tentativo e l'altro.
HEALTHCHECK_RETRIES=15
HEALTHCHECK_DELAY=4

# --- Modalita' nativa (systemd) ---------------------------------------------
# Nome del servizio systemd del backend.
SERVICE_NAME=dashboard-raspi
# Utente di sistema (NON privilegiato) che esegue il servizio.
# Deve ESISTERE gia' sul Raspberry. Se non hai un utente dedicato,
# usa lo stesso valore di DEPLOY_USER.
SERVICE_USER=deploy
# Il deploy native richiede sudo NON interattivo almeno per:
#   /usr/bin/install, /usr/bin/systemctl
# Se servi il frontend con nginx dallo stesso host, spesso serve anche:
#   /usr/sbin/nginx
# Numero massimo di release da conservare per il rollback.
KEEP_RELEASES=5

# Con la modalita' native ricorda di adattare anche ${DEPLOY_PATH}/.env:
# DATABASE_URL, SSH_KEYS_DIR e DEVICES_CONFIG_PATH devono puntare a path reali
# sul Raspberry, non ai path Docker /data, /secrets e /config.

# --- Opzioni SSH avanzate (opzionali) ---------------------------------------
# Path della chiave privata da usare (se diversa dal default ~/.ssh/id_*).
# Su Windows puoi usare un path stile C:/Users/nome/.ssh/id_ed25519
SSH_IDENTITY_FILE=
# Path di un file known_hosts dedicato. Se valorizzato, abilita la verifica
# stretta dell'host key (StrictHostKeyChecking=yes) contro questo file.
SSH_KNOWN_HOSTS_FILE=
