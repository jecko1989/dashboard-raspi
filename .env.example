# =============================================================================
# Raspberry Dashboard - Esempio variabili d'ambiente
# =============================================================================
# Copia questo file in ".env" e personalizza i valori.
#   cp .env.example .env
# NON committare mai il file .env reale.
# =============================================================================

# ---------------------------------------------------------------------------
# Backend
# ---------------------------------------------------------------------------
# Nome applicazione / ambiente
APP_NAME="Raspberry Dashboard"
ENVIRONMENT="development"          # development | production
LOG_LEVEL="INFO"                  # DEBUG | INFO | WARNING | ERROR

# Database. SQLite di default (file su volume). Per migrare a Postgres:
# DATABASE_URL="postgresql+psycopg://user:password@db:5432/raspberry_dashboard"
# In modalita' native sostituisci /data con un path reale sul Raspberry,
# ad es. /home/<utente>/workspace/dashboard-raspi/raspberry_dashboard.db
DATABASE_URL="sqlite:////data/raspberry_dashboard.db"

# Path (dentro il container backend) della cartella con le chiavi SSH.
# In docker-compose.yml questa cartella viene montata da ./secrets/ssh.
# In modalita' native usa un path reale, es.
# /home/<utente>/workspace/dashboard-raspi/secrets/ssh
SSH_KEYS_DIR="/secrets/ssh"

# Path del file di configurazione device (dentro il container backend).
# In modalita' native usa un path reale, es.
# /home/<utente>/workspace/dashboard-raspi/config/devices.yaml
DEVICES_CONFIG_PATH="/config/devices.yaml"

# Se in modalita' native servi il frontend con nginx da una directory sotto
# /home/<utente>, il web server deve poter attraversare le directory padre.

# Timeout (secondi) per le connessioni TCP/SSH ai Raspberry.
SSH_CONNECT_TIMEOUT=8

# (Opzionale) Path a un file known_hosts per verificare le host key SSH.
# Se vuoto e SSH_AUTO_ADD_HOST_KEYS=true, le host key vengono aggiunte al volo (TOFU).
SSH_KNOWN_HOSTS_PATH=""
SSH_AUTO_ADD_HOST_KEYS="true"

# Sicurezza / Auth (usato dalle fasi successive; placeholder in Fase 1).
# Genera un secret robusto, es: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY="CHANGE_ME_generate_a_long_random_secret"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60

# Utente admin iniziale della dashboard (bootstrap, fasi successive).
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="CHANGE_ME_strong_password"

# CORS: origini frontend consentite (separate da virgola).
CORS_ORIGINS="http://localhost:5173,http://localhost:8080"

# Scheduler: intervallo (secondi) tra i cicli di raccolta metriche.
METRICS_INTERVAL_SECONDS=60

# Rate limiting: numero massimo di comandi remoti al minuto per client IP.
COMMAND_RATE_LIMIT_PER_MINUTE=10

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# URL base delle API backend, usato dal frontend in build/run.
VITE_API_BASE_URL="http://localhost:8000"
